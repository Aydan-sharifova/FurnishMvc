<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Furnish Admin</title>
    <style>
        :root {
            --bg: #f5f7fb;
            --panel: #ffffff;
            --text: #17202a;
            --muted: #667085;
            --line: #d9e2ec;
            --brand: #176b87;
            --brand-dark: #0f4f63;
            --danger: #bd2c2c;
            --danger-bg: #fff1f1;
            --success-bg: #eaf8f0;
            --success-text: #176b3a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text);
            font-family: Arial, Helvetica, sans-serif;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .admin-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 240px 1fr;
        }

        .admin-sidebar {
            background: #111827;
            color: #f8fafc;
            padding: 24px 18px;
        }

        .admin-logo {
            display: block;
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 28px;
        }

        .admin-nav {
            display: grid;
            gap: 8px;
        }

        .admin-nav a {
            border-radius: 8px;
            color: #cbd5e1;
            padding: 11px 12px;
        }

        .admin-nav a.active,
        .admin-nav a:hover {
            background: #1f2937;
            color: #ffffff;
        }

        .admin-main {
            min-width: 0;
            padding: 28px;
        }

        .page-header {
            align-items: center;
            display: flex;
            gap: 16px;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .page-header h1 {
            font-size: 28px;
            line-height: 36px;
            margin: 0;
        }

        .page-header p {
            color: var(--muted);
            margin: 4px 0 0;
        }

        .panel {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 8px;
            overflow: hidden;
        }

        .panel-body {
            padding: 22px;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            border-collapse: collapse;
            min-width: 760px;
            width: 100%;
        }

        th,
        td {
            border-bottom: 1px solid var(--line);
            padding: 14px 16px;
            text-align: left;
            vertical-align: middle;
        }

        th {
            color: var(--muted);
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
        }

        tr:last-child td {
            border-bottom: 0;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .btn {
            border: 1px solid transparent;
            border-radius: 7px;
            cursor: pointer;
            display: inline-flex;
            font-size: 14px;
            font-weight: 700;
            line-height: 20px;
            padding: 9px 13px;
        }

        .btn-primary {
            background: var(--brand);
            color: #ffffff;
        }

        .btn-primary:hover {
            background: var(--brand-dark);
        }

        .btn-light {
            background: #ffffff;
            border-color: var(--line);
            color: var(--text);
        }

        .btn-danger {
            background: var(--danger);
            color: #ffffff;
        }

        .badge {
            border-radius: 999px;
            display: inline-flex;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 9px;
        }

        .badge-ok {
            background: var(--success-bg);
            color: var(--success-text);
        }

        .badge-muted {
            background: #eef2f7;
            color: #475467;
        }

        .form-grid {
            display: grid;
            gap: 18px;
            max-width: 760px;
        }

        .form-row {
            display: grid;
            gap: 7px;
        }

        .form-row label {
            color: #344054;
            font-size: 14px;
            font-weight: 700;
        }

        .form-control {
            border: 1px solid #cbd5e1;
            border-radius: 7px;
            color: var(--text);
            font: inherit;
            min-height: 42px;
            padding: 9px 11px;
            width: 100%;
        }

        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

        .check-row {
            align-items: center;
            display: flex;
            gap: 10px;
        }

        .check-row input {
            height: 18px;
            width: 18px;
        }

        .text-danger,
        .validation-summary-errors {
            color: var(--danger);
            font-size: 14px;
        }

        .alert {
            border-radius: 8px;
            margin-bottom: 18px;
            padding: 12px 14px;
        }

        .alert-success {
            background: var(--success-bg);
            color: var(--success-text);
        }

        .alert-danger {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .detail-list {
            display: grid;
            gap: 14px;
            max-width: 820px;
        }

        .detail-row {
            border-bottom: 1px solid var(--line);
            display: grid;
            gap: 8px;
            grid-template-columns: 180px 1fr;
            padding-bottom: 14px;
        }

        .detail-row dt {
            color: var(--muted);
            font-weight: 700;
        }

        .detail-row dd {
            margin: 0;
        }

        .thumb {
            background: #eef2f7;
            border: 1px solid var(--line);
            border-radius: 8px;
            height: 72px;
            object-fit: contain;
            width: 96px;
        }

        .empty-state {
            color: var(--muted);
            padding: 26px;
            text-align: center;
        }

        .stats {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            margin-bottom: 22px;
        }

        .stat-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 20px;
        }

        .stat-card span {
            color: var(--muted);
            display: block;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .stat-card strong {
            font-size: 30px;
            line-height: 38px;
        }

        @@media (max-width: 860px) {
            .admin-shell {
                grid-template-columns: 1fr;
            }

            .admin-sidebar {
                position: static;
            }

            .admin-nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .admin-main {
                padding: 18px;
            }

            .page-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .detail-row {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 520px) {
            .admin-nav,
            .stats {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    @{
        string? currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-logo" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Furnish Admin</a>
            <nav class="admin-nav">
                <a class="@(currentController == "Dashboard" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="@(currentController == "Categories" ? "active" : "")" asp-area="Admin" asp-controller="Categories" asp-action="Index">Categories</a>
                <a class="@(currentController == "Products" ? "active" : "")" asp-area="Admin" asp-controller="Products" asp-action="Index">Products</a>
                <a class="@(currentController == "Sliders" ? "active" : "")" asp-area="Admin" asp-controller="Sliders" asp-action="Index">Sliders</a>
                <a asp-area="" asp-controller="Home" asp-action="Index">View Site</a>
            </nav>
        </aside>
        <main class="admin-main">
            @if (TempData["SuccessMessage"] is not null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
