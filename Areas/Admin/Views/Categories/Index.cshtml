@model IEnumerable<Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <div>
        <h1>Categories</h1>
        <p>Create and manage product categories.</p>
    </div>
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Categories" asp-action="Create">Add Category</a>
</div>

<section class="panel">
    @if (Model.Any())
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Icon</th>
                        <th>Products</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Category category in Model)
                    {
                        <tr>
                            <td>@category.Name</td>
                            <td>@category.Slug</td>
                            <td>@(string.IsNullOrWhiteSpace(category.Icon) ? "-" : category.Icon)</td>
                            <td>@category.Products.Count</td>
                            <td>
                                <div class="actions">
                                    <a class="btn btn-light" asp-area="Admin" asp-controller="Categories" asp-action="Details" asp-route-id="@category.Id">Details</a>
                                    <a class="btn btn-primary" asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.Id">Edit</a>
                                    <a class="btn btn-danger" asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@category.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">No categories have been added yet.</div>
    }
</section>
