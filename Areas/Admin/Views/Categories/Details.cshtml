@model Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="page-header">
    <div>
        <h1>@Model.Name</h1>
        <p>Category details and product count.</p>
    </div>
    <div class="actions">
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-light" asp-area="Admin" asp-controller="Categories" asp-action="Index">Back to List</a>
    </div>
</div>

<section class="panel">
    <div class="panel-body">
        <dl class="detail-list">
            <div class="detail-row">
                <dt>Name</dt>
                <dd>@Model.Name</dd>
            </div>
            <div class="detail-row">
                <dt>Slug</dt>
                <dd>@Model.Slug</dd>
            </div>
            <div class="detail-row">
                <dt>Icon</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Icon) ? "-" : Model.Icon)</dd>
            </div>
            <div class="detail-row">
                <dt>Products</dt>
                <dd>@Model.Products.Count</dd>
            </div>
        </dl>
    </div>
</section>
