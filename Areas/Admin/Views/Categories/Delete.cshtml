@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-header">
    <div>
        <h1>Delete Category</h1>
        <p>Confirm category removal.</p>
    </div>
    <a class="btn btn-light" asp-area="Admin" asp-controller="Categories" asp-action="Index">Back to List</a>
</div>

<section class="panel">
    <div class="panel-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <dl class="detail-list">
            <div class="detail-row">
                <dt>Name</dt>
                <dd>@Model.Name</dd>
            </div>
            <div class="detail-row">
                <dt>Slug</dt>
                <dd>@Model.Slug</dd>
            </div>
            <div class="detail-row">
                <dt>Products</dt>
                <dd>@Model.Products.Count</dd>
            </div>
        </dl>

        <form asp-action="Delete" method="post" class="actions" style="margin-top: 22px;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-light" asp-area="Admin" asp-controller="Categories" asp-action="Index">Cancel</a>
        </form>
    </div>
</section>
