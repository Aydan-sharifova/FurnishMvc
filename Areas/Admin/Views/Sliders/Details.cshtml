@model Slider

@{
    ViewData["Title"] = "Slider Details";
}

<div class="page-header">
    <div>
        <h1>@Model.Title</h1>
        <p>Homepage slide details.</p>
    </div>
    <div class="actions">
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Sliders" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-light" asp-area="Admin" asp-controller="Sliders" asp-action="Index">Back to List</a>
    </div>
</div>

<section class="panel">
    <div class="panel-body">
        <dl class="detail-list">
            <div class="detail-row">
                <dt>Image</dt>
                <dd>
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img class="thumb" src="@Model.ImageUrl" alt="@Model.Title" />
                    }
                    else
                    {
                        <span>-</span>
                    }
                </dd>
            </div>
            <div class="detail-row">
                <dt>Discount</dt>
                <dd>@Model.DiscountText</dd>
            </div>
            <div class="detail-row">
                <dt>Title</dt>
                <dd>@Model.Title</dd>
            </div>
            <div class="detail-row">
                <dt>Description</dt>
                <dd>@Model.Description</dd>
            </div>
            <div class="detail-row">
                <dt>Price</dt>
                <dd>@Model.Price.ToString("C")</dd>
            </div>
            <div class="detail-row">
                <dt>Button</dt>
                <dd>@Model.ButtonText (@Model.ButtonLink)</dd>
            </div>
            <div class="detail-row">
                <dt>Order</dt>
                <dd>@Model.Order</dd>
            </div>
            <div class="detail-row">
                <dt>Active</dt>
                <dd>@(Model.IsActive ? "Yes" : "No")</dd>
            </div>
        </dl>
    </div>
</section>
