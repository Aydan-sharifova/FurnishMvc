@model Slider

@{
    ViewData["Title"] = "Add Slider";
}

<div class="page-header">
    <div>
        <h1>Add Slider</h1>
        <p>Add a new homepage slide.</p>
    </div>

    <a class="btn btn-light"
       asp-area="Admin"
       asp-controller="Sliders"
       asp-action="Index">
        Back to List
    </a>
</div>

<section class="panel">
    <div class="panel-body">

        <form asp-action="Create"
              method="post"
              enctype="multipart/form-data"
              class="form-grid">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-row">
                <label asp-for="DiscountText"></label>

                <input asp-for="DiscountText"
                       class="form-control" />

                <span asp-validation-for="DiscountText"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">
                <label asp-for="Title"></label>

                <input asp-for="Title"
                       class="form-control" />

                <span asp-validation-for="Title"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">
                <label asp-for="Description"></label>

                <textarea asp-for="Description"
                          class="form-control">
                </textarea>

                <span asp-validation-for="Description"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">
                <label asp-for="Price"></label>

                <input asp-for="Price"
                       type="number"
                       min="0"
                       step="0.01"
                       class="form-control" />

                <span asp-validation-for="Price"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">

                <label asp-for="Photo"></label>

                <input asp-for="Photo"
                       type="file"
                       accept="image/*"
                       class="form-control" />

                <span asp-validation-for="Photo"
                      class="text-danger">
                </span>

            </div>

            <div class="form-row">
                <label asp-for="ButtonText"></label>

                <input asp-for="ButtonText"
                       class="form-control" />

                <span asp-validation-for="ButtonText"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">
                <label asp-for="ButtonLink"></label>

                <input asp-for="ButtonLink"
                       class="form-control" />

                <span asp-validation-for="ButtonLink"
                      class="text-danger">
                </span>
            </div>

            <div class="form-row">
                <label asp-for="Order"></label>

                <input asp-for="Order"
                       type="number"
                       min="0"
                       class="form-control" />

                <span asp-validation-for="Order"
                      class="text-danger">
                </span>
            </div>

            <div class="check-row">

                <input asp-for="IsActive" />

                <label asp-for="IsActive"></label>

            </div>

            <div class="actions">

                <button type="submit"
                        class="btn btn-primary">
                    Create
                </button>

                <a class="btn btn-light"
                   asp-area="Admin"
                   asp-controller="Sliders"
                   asp-action="Index">
                    Cancel
                </a>

            </div>

        </form>

    </div>
</section>